{
  "name": "@serdnaley/metabase-mcp",
  "version": "0.2.0",
  "description": "MCP server for Metabase — 128 tools for full API coverage: dashboards, questions, collections, users, permissions, alerts, settings, and more",
  "type": "module",
  "scripts": {
    "generate-types": "bun run scripts/generate-types.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:setup": "bun run tests/setup.ts"
  },
  "bin": {
    "metabase-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "metabase",
    "mcp",
    "model-context-protocol",
    "ai",
    "dashboards"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Serdnaley/metabase-mcp"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  }
}
